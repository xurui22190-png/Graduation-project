        <id column="tId" property="tid" />
        <result column="tNo" property="tno" />
        <result column="tName" property="tname" />
        <result column="tSex" property="tsex" />
        <result column="tTel" property="ttel" />
        <result column="tEduLevel" property="tedulevel" />
