        <result column="tAddress" property="taddress" />
        <result column="tAccountId" property="taccountid" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        tId, tNo, tName, tSex, tTel, tEduLevel, tSchool, tAddress, tAccountId
    </sql>

</mapper>
