<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.mapper.UserinfoMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.demo.model.Userinfo">
        <id column="uid" property="uid" />
        <result column="uLog" property="ulog" />
        <result column="uPwd" property="upwd" />
        <result column="uName" property="uname" />
        <result column="uSex" property="usex" />
        <result column="uPhoto" property="uphoto" />
        <result column="uRole" property="urole" />
        <result column="uCreateDate" property="ucreatedate" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        uid, uLog, uPwd, uName, uSex, uPhoto, uRole, uCreateDate
    </sql>

</mapper>
