<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.mapper.CollegeinfoMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.demo.model.Collegeinfo">
        <id column="CID" property="cid" />
        <result column="cName" property="cname" />
        <result column="cCode" property="ccode" />
        <result column="cParentId" property="cparentid" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        CID, cName, cCode, cParentId
    </sql>

</mapper>
